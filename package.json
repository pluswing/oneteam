{
  "name": "one-team",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "vite --host 127.0.0.1 --port 3579",
    "build": "tsup src/server/index.ts --format esm --target node20 --out-dir dist/server && vite build",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src/test",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "e2e:server": "node scripts/e2e-setup.mjs && concurrently -k -s first -n api,web \"ONETEAM_DATABASE_URL=file:./.tmp/e2e/oneteam.db ONETEAM_AGENT_WORKER=false PORT=4580 tsx src/server/index.ts\" \"VITE_API_TARGET=http://127.0.0.1:4580 vite --host 127.0.0.1 --port 4579\"",
    "lint": "eslint .",
    "db:migrate": "tsx src/server/db/migrate.ts",
    "codex:version": "codex --version",
    "codex:login": "codex login",
    "codex:exec": "codex exec --dangerously-bypass-approvals-and-sandbox"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "@hono/zod-validator": "^0.7.5",
    "@libsql/client": "^0.15.15",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.10.7",
    "lucide-react": "^0.554.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@openai/codex": "^0.132.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.2.4",
    "vitest": "^4.0.14"
  }
}
